{
	"name": "@socialproof/contra",
	"author": "The Social Proof Foundation <brandon@socialproof.foundation>",
	"description": "MySo confidential transfers (Contra) client SDK",
	"version": "0.0.2",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"CHANGELOG.md",
		"README.md",
		"dist",
		"src"
	],
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/The-Social-Proof-Foundation/myso-ts-sdks.git"
	},
	"bugs": {
		"url": "https://github.com/The-Social-Proof-Foundation/myso-ts-sdks/issues/new"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "rm -rf tsconfig.tsbuildinfo ./dist",
		"build": "rm -rf dist && tsc --noEmit && tsdown",
		"codegen": "node ../codegen/dist/bin/cli.mjs generate && pnpm lint:fix",
		"prettier:check": "prettier -c --ignore-unknown .",
		"prettier:fix": "prettier -w --ignore-unknown .",
		"oxlint:check": "oxlint .",
		"oxlint:fix": "oxlint --fix",
		"lint": "pnpm run oxlint:check && pnpm run prettier:check",
		"lint:fix": "pnpm run oxlint:fix && pnpm run prettier:fix",
		"test": "vitest run"
	},
	"dependencies": {
		"@noble/curves": "^2.0.1",
		"@noble/hashes": "^2.0.1",
		"@socialproof/bcs": "workspace:^",
		"@socialproof/contra-bulletproofs-wasm": "workspace:^",
		"@socialproof/myso": "workspace:^"
	},
	"devDependencies": {
		"@socialproof/codegen": "workspace:^",
		"@types/node": "^25.0.8",
		"typescript": "^5.9.3",
		"vitest": "^4.0.17"
	},
	"peerDependencies": {
		"@socialproof/myso": "workspace:^"
	}
}
